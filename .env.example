# Copy to .env and fill in real values. Do NOT commit .env.

# Django core
DJANGO_SECRET_KEY=change-me-to-64-random-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,api.example.com

# Database (MySQL)
DB_NAME=flowapprove
DB_USER=flowapprove
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306

# CORS / CSRF (prod only — comma-separated)
CORS_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com

# JWT
JWT_ACCESS_MINUTES=15

# SSL (set to False if terminating TLS elsewhere)
SECURE_SSL_REDIRECT=True

# Email (SMTP). In dev the console backend prints emails to stdout.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@flowapprove.local
